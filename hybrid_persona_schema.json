{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Hybrid Persona-Driven Data Synthesis Record",
  "type": "object",
  "required": [
    "record_id",
    "source_mode",
    "anchor_persona_id",
    "persona_macro",
    "intent_level",
    "topic_product_category",
    "text",
    "output_type",
    "label_confidence",
    "review_status"
  ],
  "properties": {
    "record_id": {
      "type": "string"
    },
    "source_mode": {
      "type": "string",
      "enum": [
        "observed",
        "script_generated",
        "personahub_zero_shot",
        "personahub_few_shot",
        "hybrid"
      ]
    },
    "anchor_persona_id": {
      "type": "string"
    },
    "persona_macro": {
      "type": "string",
      "enum": [
        "Enterprise IT Buyer",
        "Individual User"
      ]
    },
    "persona_micro": {
      "type": "string"
    },
    "intent_level": {
      "type": "string",
      "enum": [
        "Low",
        "Medium",
        "High"
      ]
    },
    "topic_product_category": {
      "type": "string"
    },
    "job_to_be_done": {
      "type": "string"
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "success_metric": {
      "type": "string"
    },
    "decision_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "vocabulary": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "text": {
      "type": "string"
    },
    "output_type": {
      "type": "string",
      "enum": [
        "search_query",
        "assistant_prompt",
        "transcript_turn"
      ]
    },
    "label_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "label_confidence": {
      "type": "string",
      "enum": [
        "High",
        "Medium",
        "Low"
      ]
    },
    "realism_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "drift_flags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "persona_drift",
          "intent_drift",
          "topic_drift",
          "vocabulary_drift",
          "constraint_drift"
        ]
      }
    },
    "review_status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected"
      ]
    }
  }
}